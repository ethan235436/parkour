local BASE_SOUND = "rbxassetid://9118823101" -- tone/piano sound
local PPQ = 480 -- standard MIDI ticks per beat (adjust if needed)
local BPM = 120 -- fallback tempo

------------------------------------------------
-- STATE
------------------------------------------------
local notes = {}
local playing = false
local startTime = 0
local index = 1

------------------------------------------------
-- PARSE MIDI CSV
------------------------------------------------
local function parse(data)
	local out = {}

	for line in string.gmatch(data, "[^\n]+") do
		local track, time, event, note, vel =
			string.match(line, "(%d+),%s*(%d+),%s*([%w_]+),%s*(%d+),%s*(%d+)")

		if time and note and vel then
			time = tonumber(time)
			note = tonumber(note)
			vel = tonumber(vel)

			if event == "Note_on_c" and vel > 0 then
				table.insert(out, {
					time = time,
					note = note,
					vel = vel
				})
			end
		end
	end

	table.sort(out, function(a,b)
		return a.time < b.time
	end)

	return out
end

notes = parse(MIDI_DATA)

------------------------------------------------
-- SOUND PLAYER
------------------------------------------------
local function playNote(note, vel)
	local s = Instance.new("Sound")
	s.SoundId = BASE_SOUND
	s.Volume = math.clamp(vel / 127, 0.1, 1)
	s.PlaybackSpeed = 2 ^ ((note - 60) / 12)
	s.Parent = workspace
	s:Play()

	game.Debris:AddItem(s, 2)
end

------------------------------------------------
-- START / STOP
------------------------------------------------
local function startMusic()
	startTime = os.clock()
	index = 1
	playing = true
end

local function stopMusic()
	playing = false
	index = 1
end

------------------------------------------------
-- PLAY LOOP
------------------------------------------------
RunService.RenderStepped:Connect(function()
	if not playing then return end
	if not notes[index] then return end

	local secondsPerTick = (60 / BPM) / PPQ
	local elapsed = os.clock() - startTime

	while notes[index] and (notes[index].time * secondsPerTick) <= elapsed do
		local n = notes[index]
		playNote(n.note, n.vel)
		index += 1
	end
end)

------------------------------------------------
-- TOGGLE (U KEY)
------------------------------------------------
UIS.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode.U then
		if playing then
			stopMusic()
		else
			startMusic()
		end
	end
end)
