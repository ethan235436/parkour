-- PLAYER ESP FLASH / TRACKER (Z HOLD)
------------------------------------------------

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

local FADE_TIME = 0.25

local zHeld = false
local trackedPlayers = {}

------------------------------------------------
-- CREATE ESP
------------------------------------------------

local function createESP(plr, permanent)
	if not plr.Character then
		return
	end

	local existing = plr.Character:FindFirstChild("FlashESP")

	if existing then
		existing:Destroy()
	end

	local highlight = Instance.new("Highlight")
	highlight.Name = permanent and "TrackedESP" or "FlashESP"
	highlight.Adornee = plr.Character
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

	highlight.FillColor = Color3.fromRGB(0, 220, 255)
	highlight.OutlineColor = Color3.fromRGB(150, 245, 255)

	highlight.FillTransparency = 1
	highlight.OutlineTransparency = 1

	highlight.Parent = plr.Character

	TweenService:Create(
		highlight,
		TweenInfo.new(
			FADE_TIME,
			Enum.EasingStyle.Quad,
			Enum.EasingDirection.Out
		),
		{
			FillTransparency = permanent and 0.65 or 0.75,
			OutlineTransparency = 0.15
		}
	):Play()

	return highlight
end


------------------------------------------------
-- REMOVE TEMP ESP
------------------------------------------------

local function removeFlashESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character then
			local esp = plr.Character:FindFirstChild("FlashESP")

			if esp then
				local fade = TweenService:Create(
					esp,
					TweenInfo.new(
						0.25,
						Enum.EasingStyle.Quad,
						Enum.EasingDirection.In
					),
					{
						FillTransparency = 1,
						OutlineTransparency = 1
					}
				)

				fade:Play()

				task.delay(0.3, function()
					if esp then
						esp:Destroy()
					end
				end)
			end
		end
	end
end


------------------------------------------------
-- SHOW ALL WHILE HELD
------------------------------------------------

local function showEveryone()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			createESP(plr, false)
		end
	end
end


------------------------------------------------
-- TOGGLE TRACKER
------------------------------------------------

local function toggleTracker(plr)
	if not plr or plr == player then
		return
	end

	if trackedPlayers[plr] then
		trackedPlayers[plr] = nil

		if plr.Character then
			local esp = plr.Character:FindFirstChild("TrackedESP")
			if esp then
				esp:Destroy()
			end
		end

		if addLog then
			addLog("Removed tracker: "..plr.Name)
		end

	else
		trackedPlayers[plr] = true
		createESP(plr, true)

		if addLog then
			addLog("Tracking: "..plr.Name)
		end
	end
end


------------------------------------------------
-- KEEP TRACKERS AFTER RESPAWN
------------------------------------------------

Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(function()
		task.wait(1)

		if trackedPlayers[plr] then
			createESP(plr, true)
		end
	end)
end)


------------------------------------------------
-- CLICK PLAYER WHILE Z HELD
------------------------------------------------

mouse.Button1Down:Connect(function()
	if not zHeld then
		return
	end

	local target = mouse.Target

	if target then
		local character = target:FindFirstAncestorOfClass("Model")

		if character then
			local plr = Players:GetPlayerFromCharacter(character)

			if plr then
				toggleTracker(plr)
			end
		end
	end
end)


------------------------------------------------
-- Z HOLD DETECTION
------------------------------------------------

UIS.InputBegan:Connect(function(input, processed)
	if processed or scriptKilled then
		return
	end

	if input.KeyCode == Enum.KeyCode.Z then
		zHeld = true
		showEveryone()
	end
end)


UIS.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.Z then
		zHeld = false
		removeFlashESP()

		-- restore permanent trackers
		for plr in pairs(trackedPlayers) do
			if plr.Character then
				createESP(plr, true)
			end
		end
	end
end)
