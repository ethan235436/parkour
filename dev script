local function teleportToCoords()
	local char = player.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local text = box.Text

	local x, y, z

	-- FORMAT 1: YOUR CLIPBOARD FORMAT
	x = string.match(text, "X:%s*([%-%d%.]+)")
	y = string.match(text, "Y:%s*([%-%d%.]+)")
	z = string.match(text, "Z:%s*([%-%d%.]+)")

	-- FORMAT 2: fallback comma format
	if not x or not y or not z then
		x, y, z = string.match(text, "([%-%d%.]+)%s*,%s*([%-%d%.]+)%s*,%s*([%-%d%.]+)")
	end

	if not x or not y or not z then
		addLog("Invalid coords format")
		return
	end

	local pos = Vector3.new(tonumber(x), tonumber(y), tonumber(z))
	root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))

	addLog("Teleported to coords")
end

